# Copy to .env and set real values. Used by docker-compose.yml.
# Generate a strong key, e.g.:  openssl rand -hex 32

# Shared API key — used by BOTH backend (auth_key) and frontend (API_KEY).
QRGATE_AUTH_KEY=change-me-to-a-long-random-key

# Public URLs (browser-facing).
QRGATE_BACKEND_URL=https://qrgate-backend.example.com/
QRGATE_FRONTEND_ORIGIN=https://tickets.example.com
QRGATE_ORIGIN_URL=https://tickets.example.com/

# Timezone (IANA name).
QRGATE_TIMEZONE=Europe/Berlin

# Setup wizard link printed in the backend logs on first start.
QRGATE_SETUP_URL=http://localhost:8080/install

# Role accounts (comma-separated usernames + shared password per role).
QRGATE_ADMIN_USERNAMES=admin
QRGATE_ADMIN_PASSWORD=change-me-admin
QRGATE_TICKETFLOW_USERNAMES=ticketflow
QRGATE_TICKETFLOW_PASSWORD=change-me-ticketflow
QRGATE_HANDHELD_USERNAMES=handheld
QRGATE_HANDHELD_PASSWORD=change-me-handheld

# SMTP (ticket emails).
QRGATE_SMTP_SERVER=smtp.example.com
QRGATE_SMTP_PORT=587
QRGATE_SMTP_USER=user@example.com
QRGATE_SMTP_PASSWORD=change-me-smtp
